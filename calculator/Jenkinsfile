def toolchain

pipeline {
    agent { label 'docker' }

    parameters {
        booleanParam(
            name: 'ARTIFACT_ONLY',
            defaultValue: false,
            description: 'Skip lint/tests; only build and archive the artifact.'
        )
        booleanParam(
            name: 'RELEASE',
            defaultValue: false,
            description: 'Force a GitHub Release for this build (manual action).'
        )
        string(
            name: 'RELEASE_VERSION',
            defaultValue: '',
            description: 'Release tag/name. Empty -> build-<BUILD_NUMBER>.'
        )
    }

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '20', artifactNumToKeepStr: '10'))
    }

    triggers {
        // Full CI on new commits (webhook) + poll fallback.
        githubPush()
        pollSCM('H/5 * * * *')
        // Daily artifact regeneration (~02:xx America/Sao_Paulo), main only.
        cron(env.BRANCH_NAME == 'main' ? 'H 2 * * *' : '')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Detect mode') {
            steps {
                script {
                    def daily = currentBuild
                        .getBuildCauses('hudson.triggers.TimerTrigger$TimerTriggerCause')
                        .size() > 0
                    env.ARTIFACT_MODE = (daily || params.ARTIFACT_ONLY) ? 'true' : 'false'
                    echo "Artifact-only mode: ${env.ARTIFACT_MODE} (daily=${daily}, param=${params.ARTIFACT_ONLY})"
                    
                    def isTag = env.TAG_NAME?.trim()
                    def isMain = env.BRANCH_NAME == 'main'
                    env.RELEASE_MODE = (isTag || (isMain && params.RELEASE)) ? 'true' : 'false'
                    if (isTag) {
                        env.REL_VERSION = env.TAG_NAME
                    } else {
                        env.REL_VERSION = params.RELEASE_VERSION?.trim() ? params.RELEASE_VERSION.trim() : "build-${env.BUILD_NUMBER}"
                    }
                    echo "Release mode: ${env.RELEASE_MODE} (version=${env.REL_VERSION}, tag=${isTag ?: 'none'})"
                }
            }
        }

        stage('Build toolchain image') {
            steps {
                script {
                    def tag = 'calc-toolchain:' + env.BRANCH_NAME.replaceAll(/[^A-Za-z0-9._-]/, '-').toLowerCase()
                    toolchain = docker.build(tag, "calculator")
                }
            }
        }

        stage('Code check (lint + format)') {
            when { expression { env.ARTIFACT_MODE != 'true' } }
            steps {
                script {
                    toolchain.inside {
                        dir('calculator') { sh 'make check' }
                    }
                }
            }
        }

        stage('Unit tests') {
            when { expression { env.ARTIFACT_MODE != 'true' } }
            steps {
                script {
                    toolchain.inside {
                        dir('calculator') { sh 'make unittest' }
                    }
                }
            }
        }

        stage('Build artifact') {
            steps {
                script {
                    toolchain.inside {
                        dir('calculator') { sh 'make' }
                    }
                }
                sh '''
                    printf 'build=%s\\ncommit=%s\\ndate=%s\\n' \
                        "$BUILD_NUMBER" "$GIT_COMMIT" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
                        > calculator/bin/BUILDINFO.txt
                '''
            }
        }

        stage('Archive artifact') {
            steps {
                archiveArtifacts artifacts: 'calculator/bin/**', fingerprint: true
            }
        }

        stage('GitHub Release') {
            when {
                expression { env.RELEASE_MODE == 'true' }
            }
            steps {
                withCredentials([usernamePassword(credentialsId: 'test-devops-gh-token', usernameVariable: 'GH_USER', passwordVariable: 'GITHUB_TOKEN')]) {
                    sh '''
                        set -eu
                        REPO_SLUG=$(git config --get remote.origin.url \
                            | sed -E 's#(git@github.com:|https://github.com/)##; s#\\.git$##')
                        export REPO_SLUG GITHUB_TOKEN
                        export REL_VERSION="${REL_VERSION}"
                        export GIT_COMMIT="${GIT_COMMIT}"
                        export ASSETS="calculator/bin/calculator calculator/bin/BUILDINFO.txt"
                        sh calculator/ci/github-release.sh
                    '''
                }
            }
        }
    }

    post {
        always {
            sh 'docker image prune -f >/dev/null 2>&1 || true'
            cleanWs()
        }
        failure {
            echo 'CRITICAL: pipeline failed. Downstream stages skipped.'
        }
        success {
            script {
                if (env.ARTIFACT_MODE == 'true') {
                    echo "Artifact generated and archived (build ${env.BUILD_NUMBER})."
                } else {
                    echo 'CI passed: code checked, tests green, artifact archived.'
                }
            }
        }
    }
}
